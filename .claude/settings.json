{
    "sandbox": {
        "enabled": true
    },
    "permissions": {
        "deny": [
            "Read(**/target/**)",
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(**/*.pem)",
            "Read(**/*.key)",
            "Read(**/*.cert)",
            "Read(**/*.p12)",
            "Read(**/*.pfx)",
            "Read(**/secrets.*)",
            "Read(**/credentials.*)",
            "Read(./secrets/**)",
            "Read(./keys/**)",
            "Read(./.github/secrets/**)",
            "Edit(**/.ssh/**)",
            "Read(**/.ssh/**)",
            "Bash(rm -rf *)",
            "Bash(rm -fr *)",
            "Bash(sudo *)",
            "Bash(mkfs *)",
            "Bash(dd *)",
            "Bash(curl *|bash*)",
            "Bash(wget *|bash*)",
            "Bash(git push --force*)",
            "Bash(git push *--force*)",
            "Bash(git reset --hard*)",
            "Bash(gps --force*)",
            "Bash(gps *--force*)",
            "Edit(~/.bashrc)",
            "Edit(~/.zshrc)",
            "Edit(~/.ssh/**)",
            "Read(~/.ssh/**)",
            "Read(~/.gnupg/**)",
            "Read(~/.aws/**)",
            "Read(~/.azure/**)",
            "Read(~/.config/gh/**)",
            "Read(~/.git-credentials)",
            "Read(~/.docker/config.json)",
            "Read(~/.kube/**)",
            "Read(~/.npmrc)",
            "Read(~/.npm/**)",
            "Read(~/.pypirc)",
            "Read(~/.gem/credentials)",
            "Read(~/Library/Keychains/**)",
            "Read(~/Library/Application Support/**/metamask*/**)",
            "Read(~/Library/Application Support/**/electrum*/**)",
            "Read(~/Library/Application Support/**/exodus*/**)",
            "Read(~/Library/Application Support/**/phantom*/**)",
            "Read(~/Library/Application Support/**/solflare*/**)"
        ]
    }
}